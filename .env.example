# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── JWT ───────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ── Firebase Admin SDK ────────────────────────────────────────
# From Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=raahi-d3564
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@raahi-d3564.iam.gserviceaccount.com
# Paste the private_key value from the JSON file (keep the \n newlines)
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# ── MSG91 OTP ─────────────────────────────────────────────────
# From https://control.msg91.com → API Keys
MSG91_API_KEY=your-msg91-authkey
# From MSG91 → SMS → Templates
MSG91_TEMPLATE_ID=your-msg91-template-id

# ── Google Gemini AI ──────────────────────────────────────────
# From https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── Database (optional — currently using in-memory storage) ──
DATABASE_URL=postgresql://user:password@host:5432/raahi

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed web origins (leave blank to allow all)
# Flutter mobile apps don't send Origin, so they always work
ALLOWED_ORIGINS=https://your-web-app.com,https://admin.your-app.com
